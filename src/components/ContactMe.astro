{/* ========================================================
      SECCIÓN: CONTACTO (Grid 2x2, Títulos Interactivos)
      ======================================================== */}
  <section id="contact" class="w-full relative overflow-hidden py-16 sm:py-24 md:py-32 z-20 my-18">
    

      {/* 2. Contenedor Flex Principal */}
      <div class="max-w-7xl mx-auto px-6 md:px-8 flex flex-col lg:flex-row gap-8 lg:gap-16 justify-between z-10">

          {/* 2.1 SIDEBAR VERTICAL IZQUIERDO */}
          <div class="hidden lg:flex flex-col items-center w-12 border-r border-dev-border/50 pr-8 mt-32">
              <div class="flex gap-16 text-[0.65rem] font-code tracking-[0.3em] uppercase text-dev-muted -rotate-180" style="writing-mode: vertical-rl;">
                  <span>Availability</span>
                  <span>Location</span>
                  <span>Networking</span>
              </div>
          </div>

          {/* 2.2 CONTENIDO PRINCIPAL CENTRADO */}
          <div class="flex-1 w-full max-w-4xl py-8">


            <div class="xl:hidden md:hidden sm:flex flex-col justify-start border-l border-dev-border/50 pt-8 w-auto mb-20">
              <h2 class=" gap-5 text-[4rem] sm:text-[6rem] font-code font-black uppercase tracking-tighter leading-[0.85] select-none flex flex-col items-start cursor-default transition-colors duration-500 ease-in-out text-dev-muted hover:text-dev-primary [-webkit-text-stroke:2px_currentColor] [-webkit-text-fill-color:transparent] hover:[-webkit-text-fill-color:currentColor]">
                  <span class="block">CONTACTOS</span>

              </h2>
          </div>
    

              {/* GRID TIPOGRÁFICO DE CONTACTO */}
              {/* FIX: sm:grid-cols-2 garantiza que se vea en formato 2x2 desde la resolución tablet (640px+) */}
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 sm:gap-x-12 gap-y-12 sm:gap-y-16 pt-4">
                  
                  {/* Cuadrante 1: Email (Ocupa 2 columnas en tablet/PC) */}
                  <div class="col-span-1 sm:col-span-2">
                      <span class="block text-[0.65rem] font-code text-dev-muted uppercase tracking-[0.2em] mb-4">
                          // Drop a message
                      </span>
                      <a href="mailto:hola@fernando.dev" class="text-3xl sm:text-5xl md:text-6xl lg:text-[4rem] font-normal font-code text-dev-primary hover:text-orange-500 transition-colors duration-300 wrap-break-words leading-none">
                          fer.obando1.10.4 <br/> @gmail.com
                      </a>
                  </div>

                  {/* Cuadrante 2: Social Networks */}
                  <div>
                      <span class="block text-[0.65rem] font-code text-dev-muted uppercase tracking-[0.2em] mb-6">
                      </span>
                      <ul class="flex flex-col gap-5 font-code text-base sm:text-lg text-dev-primary">
                          <li>
                              <a href="https://github.com/tu-usuario" target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors inline-flex items-center gap-3 group">
                                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dev-muted group-hover:text-orange-500 transition-colors"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                                  GitHub <span class="text-dev-muted font-normal group-hover:text-orange-500 transition-colors">↗</span>
                              </a>
                          </li>
                          <li>
                              <a href="https://linkedin.com/in/tu-perfil" target="_blank" rel="noopener noreferrer" class="hover:text-orange-500 transition-colors inline-flex items-center gap-3 group">
                                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-dev-muted group-hover:text-orange-500 transition-colors"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
                                  LinkedIn <span class="text-dev-muted font-normal group-hover:text-orange-500 transition-colors">↗</span>
                              </a>
                          </li>
                      </ul>
                  </div>

                  {/* Cuadrante 3: Documentación */}
                  <div>
                      <span class="block text-[0.65rem] font-code text-dev-muted uppercase tracking-[0.2em] mb-6">
                          // Documentation
                      </span>
                      <ul class="flex flex-col gap-5 font-code text-base sm:text-lg text-dev-primary">
                          <li>
                              <a href="/Fernando_Obando_CV.pdf" download class="hover:text-orange-500 transition-colors inline-flex items-center gap-3 group">
                                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-dev-muted group-hover:text-orange-500 transition-colors">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                  </svg>
                                  Descargar CV (PDF) 
                              </a>
                          </li>
                      </ul>
                  </div>

                  {/* Cuadrante 4: Ubicación */}
                  <div>
                      <span class="block text-[0.65rem] font-code text-dev-muted uppercase tracking-[0.2em] mb-6">
                          // Current Location
                      </span>
                      <div class="flex items-start gap-3 sm:gap-4">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 sm:w-6 sm:h-6 text-dev-muted shrink-0 mt-0.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                          <div>
                              <p class="font-code text-base sm:text-lg text-dev-primary font-light tracking-wide mb-1">
                                  Managua, Nicaragua
                              </p>
                              <p class="font-code text-[0.65rem] sm:text-xs text-dev-muted uppercase tracking-widest">
                                  CST (UTC-6)
                              </p>
                          </div>
                      </div>
                  </div>

                  {/* Cuadrante 5: Status */}
                  <div>
                      <span class="block text-[0.65rem] font-code text-dev-muted uppercase tracking-[0.2em] mb-6">
                          // Status
                      </span>
                      <div class="flex items-start gap-3 sm:gap-4">
                          <div class="w-5 h-5 sm:w-6 sm:h-6 flex items-center justify-center shrink-0 mt-0.5">
                              <span class="relative flex h-2 w-2 sm:h-2.5 sm:w-2.5 items-center justify-center">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                              </span>
                          </div>
                          <div>
                              <p class="font-code text-base sm:text-lg text-dev-primary font-light tracking-wide mb-1">
                                  Open for Work
                              </p>
                              <p class="font-code text-[0.65rem] sm:text-xs text-dev-muted uppercase tracking-widest">
                                  Remote / Full-time
                              </p>
                          </div>
                      </div>
                  </div>

              </div>
          </div>

          {/* 2.3 SIDEBAR DERECHO ("LET'S CONNECT") APILADO */}
          {/* FIX: Hereda el mismo hover interactivo de 'C' y 'CONTACT' */}
          <div class="hidden xl:flex flex-col justify-start border-l border-dev-border/50 pl-8 lg:pl-12 pt-8 w-auto">
              <h2 class="gap-5 text-[4.5rem] xl:text-[12rem] font-code font-black uppercase tracking-tighter leading-[0.85] select-none flex flex-col items-start cursor-default transition-colors duration-500 ease-in-out text-dev-muted hover:text-dev-primary [-webkit-text-stroke:2px_currentColor] [-webkit-text-fill-color:transparent] hover:[-webkit-text-fill-color:currentColor]">
                  <span class="block">CON</span>
                  <span class="block">TAC</span>
                  <span class="block">TOS</span>
              </h2>
          </div>
       
      </div>
  </section>