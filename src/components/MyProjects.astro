---
import { getCollection } from "astro:content";

// Obtenemos todos los proyectos de tu carpeta src/content/projects/
const allProjects = await getCollection("projects");

---

<section id="projects" class="w-full max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32 relative z-20">
    
    <div class="mb-16">
        <h2 class="text-3xl md:text-5xl font-code font-bold text-dev-primary uppercase tracking-widest">
            MIS PROYECTOS
        </h2>
        <div class="w-16 h-1 bg-orange-500 mt-4 rounded-full"></div>
    </div>

    <div class="flex flex-col gap-12">
        
        {allProjects.map((project) => (
            <article class="flex flex-col lg:flex-row bg-dev-surface  border-t border-dev-border overflow-hidden group hover:border-dev-primary/50 transition-colors duration-500 shadow-lg">
                
                {/* IZQUIERDA: Imagen */}
                <div class="w-full lg:w-3/5 bg-dev-bg/50 p-4 md:p-8 border-b lg:border-b-0 lg:border-r border-dev-border flex items-center justify-center">
                    <div class="w-full aspect-video overflow-hidden border border-dev-border/50 shadow-inner relative flex items-center justify-center bg-zinc-900/20">
                        {project.data.mainImage ? (
                            <img src={project.data.mainImage} alt={project.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                        ) : (
                            <span class="text-dev-muted font-code tracking-widest uppercase">Vista Previa: {project.data.title}</span>
                        )}
                    </div>
                </div>

                {/* DERECHA: Información */}
                <div class="w-full lg:w-2/5 p-8 md:p-12 flex flex-col justify-center">
                    
                    <span class="text-orange-500 font-bold font-code uppercase tracking-widest text-xs md:text-sm mb-3 block">
                        {project.data.category}
                    </span>
                    
                    <h3 class="text-4xl md:text-5xl font-bold text-dev-primary font-code mb-4">
                        {project.data.title}
                    </h3>

                    <p class="text-dev-muted text-base md:text-lg mb-8 leading-relaxed line-clamp-3">
                        {project.data.description}
                    </p>

                    {/* Stack de Tecnologías */}
                    <div class="flex flex-wrap gap-3 mb-10">
                        {project.data.technologies?.map((tech) => (
                            <span class="flex items-center gap-1 px-4 py-2 bg-dev-bg border border-dev-border rounded-full text-sm font-code text-dev-primary transition-colors hover:border-dev-primary/50">
                                <img src={tech.icon} alt="" srcset="" class="w-3 h-3 object-contain" 
                            loading="lazy" />
                                {tech.name}
                            </span>
                        ))}
                    </div>

                    {/* Botones de Acción */}
                    <div class="mt-auto pt-6 border-t border-dev-border/30 flex gap-4">
                        
                        {/* Este enlace usa `project.slug` (o `project.id` en Astro 5) 
                            para enviarte dinámicamente a la ruta de ese proyecto.
                        */}
                        <a href={`/projects/${project.id}`} class="inline-flex items-center gap-3 text-dev-primary font-bold font-code tracking-widest text-lg group-hover:text-orange-500 transition-colors duration-300">
                            Ver Detalles
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                            </svg>
                        </a>
                        
                        {/* Botón directo a GitHub (Se oculta en móviles muy pequeños para no romper el layout) */}
                        {project.data.githubLink && (
                           <a href={project.data.githubLink} target="_blank" rel="noopener noreferrer" class="hidden xl:inline-flex items-center gap-2 text-dev-muted hover:text-dev-primary font-code text-sm transition-colors duration-300 border border-transparent hover:border-dev-border px-3 py-1 rounded-full">
                              GitHub 
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                           </a>
                        )}

                    </div>

                </div>
            </article>
        ))}
    </div>
</section>